# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string (required)
# Examples:
#   Local: postgresql://user:password@localhost:5432/chatconnect
#   Neon:  postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   Supabase: postgresql://postgres.xxx:password@aws-0-xx.pooler.supabase.com:6543/postgres?sslmode=require
#   Use quotes if the password contains special characters: DATABASE_URL="..."
DATABASE_URL=

# Server port (required for api-server)
PORT=5000

# Session secret (defaults to a dev string if not set)
# SESSION_SECRET=your-random-secret
